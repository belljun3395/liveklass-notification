{
  "uid": "notification-k6",
  "title": "Notification DashBoard",
  "description": "k6 부하 테스트 중 서버 모니터링 대시보드",
  "tags": ["notification", "k6", "load-test"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "fiscalYearStartMonth": 0,
  "liveNow": true,
  "panels": [

    {
      "id": 100,
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Request Rate",
      "description": "초당 HTTP 요청 수",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"liveklass-notification\"}[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "description": "5xx 응답 비율",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"liveklass-notification\", outcome=\"SERVER_ERROR\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"liveklass-notification\"}[1m]))",
          "legendFormat": "error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Avg Latency",
      "description": "HTTP 평균 응답 시간",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum{application=\"liveklass-notification\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"liveklass-notification\"}[1m]))",
          "legendFormat": "avg",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Backlog Depth",
      "description": "PENDING 상태 Notification 잔량",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 20000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "notification_backlog_depth{application=\"liveklass-notification\"}",
          "legendFormat": "pending",
          "refId": "A"
        }
      ]
    },

    {
      "id": 101,
      "title": "HTTP Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "Request Rate by Status",
      "description": "HTTP 상태 코드별 초당 요청 수",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "5.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "4.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "2.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"liveklass-notification\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Request Latency",
      "description": "HTTP 응답 시간 (avg / max)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "max" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum{application=\"liveklass-notification\", uri=\"/api/notification-jobs\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"liveklass-notification\", uri=\"/api/notification-jobs\"}[1m]))",
          "legendFormat": "avg",
          "refId": "A"
        },
        {
          "expr": "max(http_server_requests_seconds_max{application=\"liveklass-notification\", uri=\"/api/notification-jobs\"})",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },

    {
      "id": 102,
      "title": "Notification Pipeline",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Pipeline Throughput (Rate)",
      "description": "알림 파이프라인 단계별 처리율 (건/초) - 분당 평균",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "dead_letter" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "sent" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] }
      },
      "targets": [
        {
          "expr": "rate(notification_job_total{application=\"liveklass-notification\"}[1m])",
          "legendFormat": "job_created",
          "refId": "A"
        },
        {
          "expr": "rate(notification_total{application=\"liveklass-notification\"}[1m])",
          "legendFormat": "notification_created",
          "refId": "B"
        },
        {
          "expr": "rate(notification_sent_total{application=\"liveklass-notification\"}[1m])",
          "legendFormat": "sent",
          "refId": "C"
        },
        {
          "expr": "sum(rate(notification_dead_letter_total{application=\"liveklass-notification\"}[1m]))",
          "legendFormat": "dead_letter",
          "refId": "E"
        }
      ]
    },
    {
      "id": 11,
      "title": "Pipeline Total",
      "description": "알림 파이프라인 단계별 누적 처리량 (건)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "dead_letter" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "sent" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "notification_job_total{application=\"liveklass-notification\"}",
          "legendFormat": "job_created",
          "refId": "A"
        },
        {
          "expr": "notification_total{application=\"liveklass-notification\"}",
          "legendFormat": "notification_created",
          "refId": "B"
        },
        {
          "expr": "notification_sent_total{application=\"liveklass-notification\"}",
          "legendFormat": "sent",
          "refId": "C"
        },
        {
          "expr": "sum(notification_dead_letter_total{application=\"liveklass-notification\"})",
          "legendFormat": "dead_letter",
          "refId": "E"
        }
      ]
    },
    {
      "id": 8,
      "title": "Pipeline Depth (Backlog + Retry)",
      "description": "PENDING/RETRY_WAITING 잔량 추이",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "backlog" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 30 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "retry_waiting" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "targets": [
        {
          "expr": "notification_backlog_depth{application=\"liveklass-notification\"}",
          "legendFormat": "backlog",
          "refId": "A"
        },
        {
          "expr": "notification_retry_waiting_depth{application=\"liveklass-notification\"}",
          "legendFormat": "retry_waiting",
          "refId": "C"
        }
      ]
    },
    {
      "id": 17,
      "title": "Sending Depth",
      "description": "현재 발송 중인 Notification 개수 (처리 속도 지표)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "notification_sending_depth{application=\"liveklass-notification\"}",
          "legendFormat": "sending",
          "refId": "A"
        }
      ]
    },

    {
      "id": 103,
      "title": "Internal Timers",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Batch Processing Duration",
      "description": "배치 처리 소요 시간 (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "notification_batch_processing_seconds{application=\"liveklass-notification\", quantile=\"0.5\"}",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "notification_batch_processing_seconds{application=\"liveklass-notification\", quantile=\"0.95\"}",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "notification_batch_processing_seconds{application=\"liveklass-notification\", quantile=\"0.99\"}",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "title": "Email Send",
      "description": "이메일 발송 평균 소요 시간",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(notification_email_send_batch_seconds_sum{application=\"liveklass-notification\"}[1m]) / rate(notification_email_send_batch_seconds_count{application=\"liveklass-notification\"}[1m])",
          "legendFormat": "email send avg",
          "refId": "A"
        }
      ]
    },

    {
      "id": 104,
      "title": "JVM & System",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 12,
      "title": "CPU Usage",
      "description": "JVM 프로세스 CPU 사용률",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"liveklass-notification\"}",
          "legendFormat": "process CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{application=\"liveklass-notification\"}",
          "legendFormat": "system CPU",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "title": "JVM Heap Memory",
      "description": "힙 메모리 사용량 (used / committed / max)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "committed" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [5, 5] } },
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"liveklass-notification\", area=\"heap\"})",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{application=\"liveklass-notification\", area=\"heap\"})",
          "legendFormat": "committed",
          "refId": "B"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{application=\"liveklass-notification\", area=\"heap\"})",
          "legendFormat": "max",
          "refId": "C"
        }
      ]
    },
    {
      "id": 14,
      "title": "GC Pause & Threads",
      "description": "GC 일시정지 시간 및 스레드 수",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "gc.*" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "left" }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "threads.*" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"liveklass-notification\"}[1m])",
          "legendFormat": "gc pause rate",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_live_threads{application=\"liveklass-notification\"}",
          "legendFormat": "threads (live)",
          "refId": "B"
        },
