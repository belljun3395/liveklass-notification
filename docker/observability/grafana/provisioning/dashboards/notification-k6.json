          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"liveklass-notification\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"liveklass-notification\"}",
          "legendFormat": "pending",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_max{application=\"liveklass-notification\"}",
          "legendFormat": "max",
          "refId": "D"
        }
      ]
