    {
      "id": 16,
      "title": "Connection Acquire & Timeout",
      "description": "커넥션 획득 시간 및 타임아웃 발생 추이",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "acquire.*" },
            "properties": [
              { "id": "unit", "value": "s" },
